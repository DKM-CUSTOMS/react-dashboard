PORT=3000

# Server-only secrets (do not prefix with VITE_)
AZURE_STORAGE_CONNECTION_STRING=
DOCUSIGN_PROCESSOR_URL=
DOCUSIGN_PROCESSOR_CODE=
LOGIC_APP_BESTMING_URL=
LOGIC_APP_DEBENOTE_URL=
AZURE_FUNCTION_URL=

# Optional tuning for BestMing precheck
BESTMING_PRECHECK_BATCH_SIZE=200
BESTMING_PRECHECK_ITEM_TTL_MS=600000
BESTMING_PRECHECK_MAX_CACHE_ITEMS=10000

# Legacy fallback (temporary, avoid for new deployments)
# AZURE_DOCUSIGN_PROCESSOR_URL=
# DOCUSIGN_FUNCTION_CODE=
# LEGACY_DOCUSIGN_PROCESSOR_BASE_URL=|

# Rules & Flows Platform
STREAMLINER_LOGIC_APP_URL=       # Full Logic App invoke URL for fetching declaration data
OPENAI_API_KEY=                  # Used by AI prompt checks (gpt-4o-mini)
# Import Release Dashboard
# Logic App endpoint that returns the boss query result as JSON rows/data/result.
IMPORT_RELEASE_SOURCE_URL=
# Prefer a real service token or move IRP checks into Logic App; cookie fallback is temporary.
IRP_BEARER_TOKEN=
IRP_SESSION_COOKIE=
# Local trusted-profile capture file used by the dashboard when IRP auth is refreshed manually with `npm run irp:auth`.
# For Azure Web App, keep the deployed irp.json/refresh source in sync with the trusted local machine.
IRP_CAPTURE_FILE=irp.json
IMPORT_RELEASE_POLL_LIMIT=50
# Optional: move IRP checks into Logic App to avoid browser cookie auth
IMPORT_RELEASE_IRP_URL=
IMPORT_RELEASE_EMAIL_URL=
IMPORT_RELEASE_EMAIL_TO=anas.benabbou@dkm-customs.com
IMPORT_RELEASE_EMAIL_CC=
IMPORT_RELEASE_EMAIL_SUBJECT=


# Reuse IRP bearer tokens and avoid session refresh until token has less than this remaining. Default: 2 hours.
IRP_TOKEN_REFRESH_BEFORE_MS=7200000
# Import Release automation and cooldowns
IMPORT_RELEASE_AUTOMATION_ENABLED=1
IMPORT_RELEASE_AUTOMATION_INTERVAL_MS=300000
IMPORT_RELEASE_SOURCE_COOLDOWN_MS=600000
IMPORT_RELEASE_IRP_COOLDOWN_MS=900000
IMPORT_RELEASE_FULL_COOLDOWN_MS=900000
